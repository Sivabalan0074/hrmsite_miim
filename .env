# .env.example — MIIM HRM Environment Variables
# ================================================
# இந்த file-ஐ .env என rename பண்ணி, உங்கள் values பூர்த்தி பண்ணுங்க.
# NEVER commit .env to Git! Add .env to .gitignore
#
# Setup:
#   pip install python-dotenv
#   Then add to top of app.py:
#     from dotenv import load_dotenv
#     load_dotenv()

# ─── JWT Secret Key ───────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
MIIM_SECRET_KEY=replace_with_64_char_random_string_here

# ─── SMTP Email Credentials ──────────────────────────────────
# Your Hostinger email credentials
MIIM_SMTP_USER=claude.ai@miim.co.in
MIIM_SMTP_PASS=your_email_password_here
MIIM_ADMIN_EMAIL=claude.ai@miim.co.in

# ─── Allowed CORS Origins ────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For production, add your actual domain:
#   MIIM_ALLOWED_ORIGINS=https://hrm.miim.co.in,http://localhost:5000
MIIM_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ─── Optional: Flask Settings ────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
